---
import BaseLayout from "../layouts/BaseLayout.astro";
import SmsConsent from "../components/SmsConsent.astro";
---

<BaseLayout
  title="Contact Us | Finpoint"
  description="Contact Finpoint Funding — email, phone, and address. Reach out to get started with business funding."
  active="contact"
>
  <main>
    <section class="page-hero">
      <div class="container">
        <h1 class="reveal">Contact Us</h1>
        <p class="reveal">We would love to hear from you. Reach out using the details below or send us a message.</p>
      </div>
    </section>

    <section class="section" style="padding-top: 0">
      <div class="container">
        <div class="about-grid reveal">
          <div>
            <p class="section-label">Get in Touch</p>
            <p>
              <a href="mailto:deals@finpointfunding.com">deals@finpointfunding.com</a><br />
              <a href="tel:+19736927551">(973) 692-7551</a>
            </p>
            <p style="margin-top: 1rem">
              1 Maiden Lane, 5th floor<br />
              New York, New York 10038
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section lead-form-section" id="get-started">
      <div class="container form-layout">
        <div class="reveal">
          <div class="response-pill"><span class="dot" aria-hidden="true"></span> Current Response Time: 20 min</div>
          <p class="section-label">Contact Us</p>
          <h2>Get Started.</h2>
        </div>

        <form class="form-panel reveal" data-lead-form data-form-type="lead" method="POST" novalidate>
          <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" style="display:none" />

          <div class="form-success" role="status">
            Thank you for reaching out! We'll be in touch with you shortly.
          </div>
          <div class="form-grid">
            <div class="field">
              <label for="contact-first-name">First Name</label>
              <input id="contact-first-name" name="firstName" type="text" autocomplete="given-name" required />
            </div>
            <div class="field">
              <label for="contact-last-name">Last Name</label>
              <input id="contact-last-name" name="lastName" type="text" autocomplete="family-name" required />
            </div>
            <div class="field">
              <label for="contact-email">Email</label>
              <input id="contact-email" name="email" type="email" autocomplete="email" required />
            </div>
            <div class="field">
              <label for="contact-phone">Phone Number <span class="optional">(optional)</span></label>
              <input id="contact-phone" name="phone" type="tel" autocomplete="tel" />
            </div>
            <div class="field full">
              <label for="contact-funding-amount">Funding Amount Desired</label>
              <input id="contact-funding-amount" name="fundingAmount" type="text" inputmode="decimal" />
            </div>

            <SmsConsent id="contact-sms-consent" />

            <div class="form-submit">
              <button class="btn btn-primary" type="submit" style="width: 100%">Submit</button>
            </div>
          </div>
        </form>
      </div>
    </section>
  </main>
</BaseLayout>
